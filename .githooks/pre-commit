#!/bin/sh
#
# Pre-commit hook: backend lint + tests and frontend typecheck must pass
# before committing.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Bypass in a pinch:
#   git commit --no-verify
#
set -eu

root=$(git rev-parse --show-toplevel)

# --- Backend: ruff + pytest -------------------------------------------------
cd "$root/backend"
if ! command -v uv >/dev/null 2>&1; then
  echo "pre-commit: 'uv' is not on PATH - cannot run backend checks." >&2
  echo "            Install uv (https://docs.astral.sh/uv/) or bypass with 'git commit --no-verify'." >&2
  exit 1
fi

echo "pre-commit: backend ruff check ..."
uv run ruff check .

echo "pre-commit: backend pytest ..."
uv run pytest -q

# --- Frontend: typecheck ----------------------------------------------------
cd "$root/frontend"
if ! command -v npm >/dev/null 2>&1; then
  echo "pre-commit: 'npm' is not on PATH - cannot run frontend checks." >&2
  echo "            Install Node.js (https://nodejs.org/) or bypass with 'git commit --no-verify'." >&2
  exit 1
fi

if [ ! -d node_modules ]; then
  echo "pre-commit: installing frontend dependencies (npm ci) ..."
  npm ci --silent
fi

echo "pre-commit: frontend typecheck ..."
npm run --silent typecheck

echo "pre-commit: all checks passed."
