#!/bin/sh
#
# Pre-commit hook: run checks only for the parts of the tree being committed.
#   - staged backend/  changes -> ruff check + pytest
#   - staged frontend/ changes -> typecheck (tsc) + lint (eslint) + test (vitest)
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Bypass in a pinch:
#   git commit --no-verify
#
set -eu

root=$(git rev-parse --show-toplevel)
staged=$(git diff --cached --name-only)

run_backend=0
run_frontend=0
echo "$staged" | grep -q '^backend/'  && run_backend=1 || true
echo "$staged" | grep -q '^frontend/' && run_frontend=1 || true

if [ "$run_backend" = 0 ] && [ "$run_frontend" = 0 ]; then
  echo "pre-commit: no backend/ or frontend/ changes staged; nothing to check."
  exit 0
fi

# --- Backend: ruff + pytest -------------------------------------------------
if [ "$run_backend" = 1 ]; then
  cd "$root/backend"
  if ! command -v uv >/dev/null 2>&1; then
    echo "pre-commit: 'uv' is not on PATH - cannot run backend checks." >&2
    echo "            Install uv (https://docs.astral.sh/uv/) or bypass with 'git commit --no-verify'." >&2
    exit 1
  fi
  echo "pre-commit: backend ruff check ..."
  uv run ruff check .
  echo "pre-commit: backend pytest ..."
  uv run pytest -q
else
  echo "pre-commit: no backend/ changes staged; skipping backend checks."
fi

# --- Frontend: typecheck ----------------------------------------------------
if [ "$run_frontend" = 1 ]; then
  cd "$root/frontend"
  if ! command -v npm >/dev/null 2>&1; then
    echo "pre-commit: 'npm' is not on PATH - cannot run frontend checks." >&2
    echo "            Install Node.js (https://nodejs.org/) or bypass with 'git commit --no-verify'." >&2
    exit 1
  fi
  if [ ! -d node_modules ]; then
    echo "pre-commit: installing frontend dependencies (npm ci) ..."
    npm ci --silent
  fi
  echo "pre-commit: frontend typecheck ..."
  npm run --silent typecheck
  echo "pre-commit: frontend lint ..."
  npm run --silent lint
  echo "pre-commit: frontend test ..."
  npm run --silent test
else
  echo "pre-commit: no frontend/ changes staged; skipping frontend checks."
fi

echo "pre-commit: all checks passed."
