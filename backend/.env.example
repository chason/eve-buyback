# Copy to .env and adjust. All variables are prefixed BUYBACK_.
BUYBACK_ENVIRONMENT=development
# PostgreSQL via asyncpg (ADR-0024). Create the `buyback` and `buyback_test`
# databases first; the test suite derives the `_test` name from this URL.
BUYBACK_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/buyback
BUYBACK_MARKET_HUB_ID=60003760

# Session cookie signing secret (CHANGE in production).
BUYBACK_SESSION_SECRET=dev-insecure-change-me

# EVE SSO (ADR-0004). Register an app at https://developers.eveonline.com/.
# Set the callback URL there to BUYBACK_EVE_REDIRECT_URI below.
# publicData is enough for identity + public corp lookups.
BUYBACK_EVE_CLIENT_ID=
BUYBACK_EVE_CLIENT_SECRET=
BUYBACK_EVE_REDIRECT_URI=http://localhost:5173/auth/callback
# Roles scope enables Director detection for corp registration (ADR-0015).
BUYBACK_EVE_SCOPES=publicData esi-characters.read_corporation_roles.v1
