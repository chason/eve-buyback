# docker-compose configuration — copy to .env and fill in (ADR-0012).
# .env is gitignored; never commit real secrets.

# Strong, unique random value. The app REFUSES to boot in production with an
# empty/placeholder secret. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
BUYBACK_SESSION_SECRET=

# Password for the bundled Postgres service (used by both db and app).
POSTGRES_PASSWORD=

# EVE SSO app credentials — register at https://developers.eveonline.com/.
BUYBACK_EVE_CLIENT_ID=
BUYBACK_EVE_CLIENT_SECRET=
# Must exactly match the callback URL registered on the EVE app, on your
# public origin (the SPA handles the /auth/callback route).
BUYBACK_EVE_REDIRECT_URI=https://buyback.example.com/auth/callback

# Optional overrides.
# Instance app admins (ADR-0041): comma-separated EVE character ids that operate this
# hosted instance — an authorization axis orthogonal to the per-corp member/manager/ceo
# roles, used by the accounting add-on to grant/manage access. Empty = no admins.
# BUYBACK_ADMIN_CHARACTER_IDS=90000001,90000002
BUYBACK_MARKET_HUB_ID=60003760
# ESI pins its behaviour to this date (X-Compatibility-Date header, ADR-style versioning
# by date not URL). Bump only after reviewing the ESI changelog. Default in config.py.
BUYBACK_ESI_COMPATIBILITY_DATE=2026-06-01
APP_PORT=8000
# SDE reference data auto-seeds on first boot (background); set to 0 to disable.
BUYBACK_AUTO_SEED=1
# A Fernet key encrypting the stored "Corp ESI access" refresh token (ADR-0029, 0036) —
# the one EVE token a CEO/Director connects to price at player structures AND read the
# corp roster for designating managers. Required to use either feature. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BUYBACK_TOKEN_ENCRYPTION_KEY=
# The membership scope is requested automatically as part of that grant (no extra config).
# The corp roster also refreshes automatically every day; override if needed:
#   BUYBACK_ROSTER_REFRESH_INTERVAL_SECONDS / BUYBACK_ROSTER_MANUAL_REFRESH_MIN_INTERVAL_SECONDS
# Market-price L1 cache (ADR-0033). Default is in-process memory; set "memcached" +
# the address to share the cache across processes/instances. No other change needed.
# SECURITY: memcached is UNAUTHENTICATED — bind it to loopback (`memcached -l 127.0.0.1`)
# or a private/firewalled network; reachability = read/write over cached prices. Never
# expose 11211 publicly. A slow/unreachable node degrades to the DB tier (best-effort).
BUYBACK_CACHE_BACKEND=memory
# BUYBACK_MEMCACHED_ADDR=localhost:11211
# BUYBACK_MEMCACHED_TIMEOUT_SECONDS=1.0
# Background refresh of non-Fuzzwork hub prices (ADR-0034): a scheduled job keeps
# ESI-priced hubs (non-Jita NPC stations, player structures) warm so appraisals there
# don't pay the slow ESI fetch. A pure-Jita deploy has no such hubs and it's a no-op.
# BUYBACK_MARKET_BACKGROUND_REFRESH_ENABLED=true
# BUYBACK_MARKET_REFRESH_INTERVAL_SECONDS=600
# BUYBACK_MARKET_REFRESH_INITIAL_DELAY_SECONDS=30
# ESI-overload protection (ADR-0035). ESI_MARKET_CONCURRENCY is the PROCESS-WIDE cap on
# concurrent ESI market requests; MAX_ESI_TYPES_PER_APPRAISAL caps distinct ESI-priced
# items in one appraisal (each is a separate live lookup). Together they bound outbound
# ESI load against the cold-type cache-miss attack.
# BUYBACK_ESI_MARKET_CONCURRENCY=8
# BUYBACK_MAX_ESI_TYPES_PER_APPRAISAL=100
