# Normalize line endings: store everything as LF in the repo, regardless of OS.
* text=auto eol=lf

# Explicit text types (helps diffs and avoids accidental CRLF)
*.py     text eol=lf
*.pyi    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.sql    text eol=lf
*.sh     text eol=lf
*.env    text eol=lf

# Windows-only scripts keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary assets — never touch line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.svg    text eol=lf
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.db     binary
*.sqlite binary
*.sqlite3 binary
